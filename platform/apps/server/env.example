# ── HomeOS server (M1 echo bot) ─────────────────────────────────────────────
# Copy to `.env` and fill in:  cp env.example .env
# NEVER commit the real .env — it is gitignored.

# Webhook verification token. Any long random string; paste the SAME value into
# Meta's webhook configuration. GET /webhook checks it during the handshake.
VERIFY_TOKEN=choose-a-long-random-string

# Permanent system-user access token from the Meta app (used to send messages).
# A temporary 24h token works for a quick test but expires; prefer a system-user token.
WHATSAPP_TOKEN=EAAG...your-permanent-token

# The test number's phone_number_id  (Meta → WhatsApp → API Setup).
PHONE_NUMBER_ID=1234567890

# Graph API version (optional; defaults to v21.0).
GRAPH_VERSION=v21.0

# 🔒 Allowlist gate: comma-separated E.164 family numbers allowed to use the bot.
# Use the digits-with-country-code form Meta delivers; "+" and spaces are tolerated.
ALLOWLIST=972501234567,972502222222

# Port the server listens on (optional; defaults to 3000).
PORT=3000
