{
  "name": "homeos",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "HomeOS \u2014 WhatsApp-first Hebrew family command center (monorepo)",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "pnpm --filter @homeos/server dev",
    "start": "pnpm --filter @homeos/server start",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "eval": "pnpm --filter @homeos/server eval",
    "digest:preview": "pnpm --filter @homeos/server digest:preview"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "typescript": "^5.7.2"
  }
}
